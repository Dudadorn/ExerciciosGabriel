algoritmo "Ex3"


var
 A: vetor[1..8] de inteiro
 B: vetor[1..8] de inteiro
 i: inteiro
 inicio


  para i de 1 ate 8 faca
    escreval("Digite A [", i,"]:")
    leia(A[i])
  fimpara


    para i de 1 ate 8 faca
    B[i] <- A[i] * 3
  fimpara


   escreval("vetor B:")
   para i de 1 ate 8 faca
   escreval(B[i])
   fimpara
fimalgoritmo
