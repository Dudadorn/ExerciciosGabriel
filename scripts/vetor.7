algoritmo "ex7"
var
   A: vetor[1..6] de inteiro
   B: vetor[1..6] de inteiro
   C: vetor[1..12] de inteiro
   i: inteiro
inicio
   // Leitura de A
   para i de 1 ate 6 faca
      escreva("Digite A[", i, "]: ")
      leia(A[i])
   fimpara


   // Leitura de B
   para i de 1 ate 6 faca
      escreva("Digite B[", i, "]: ")
      leia(B[i])
   fimpara


   // Copiar A para C
   para i de 1 ate 6 faca
      C[i] <- A[i]
   fimpara


   // Copiar B para C (continuação)
   para i de 1 ate 6 faca
      C[i + 6] <- B[i]
   fimpara


   // Exibir C
   escreval("Vetor C (junção de A e B):")
   para i de 1 ate 12 faca
      escreval(C[i])
   fimpara
fimalgoritmo
