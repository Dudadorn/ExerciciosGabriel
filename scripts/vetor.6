algoritmo "Ex6"


var
 A: vetor[1..6] de inteiro
 B: vetor[1..6] de inteiro
 C: vetor[1..6] de inteiro
 i: inteiro
 inicio


  para i de 1 ate 6 faca
    escreval("Digite A [", i,"]:")
    leia(A[i])
  fimpara


    para i de 1 ate 6 faca
    escreval("Digite B [", i,"]:")
    leia(B[i])
  fimpara


    para i de 1 ate 6 faca
    C[i] <- A[i] - B[i]
  fimpara


   escreval("vetor C (A - B):")
   para i de 1 ate 6 faca
   escreval(C[i])
   fimpara
fimalgoritmo
