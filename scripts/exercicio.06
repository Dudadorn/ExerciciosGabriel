algoritmo "ex6"
var
   idade: inteiro
   peso, altura: real
   menores18, total: inteiro
   somaIdade, somaAltura: real
   acima80: inteiro
inicio
   menores18 <- 0
   total <- 0
   somaIdade <- 0
   somaAltura <- 0
   acima80 <- 0

   escreval("Digite a idade (0 para parar): ")
   leia(idade)

   para i de 1 ate 5 passo 1 faca
      escreval("Digite o peso: ")
      leia(peso)

      escreval("Digite a altura: ")
      leia(altura)

      se idade < 18 entao
         menores18 <- menores18 + 1
      fimse

      se peso > 80 entao
         acima80 <- acima80 + 1
      fimse

      somaIdade <- somaIdade + idade
      somaAltura <- somaAltura + altura
      total <- total + 1

      escreval("Digite a idade (0 para parar): ")
      leia(idade)
   fimpara

   escreval("Menores de 18: ", menores18)
   escreval("Media idade: ", somaIdade / total)
   escreval("Media altura: ", somaAltura / total)
   escreval("Acima de 80kg: ", acima80)
fimalgoritmo
