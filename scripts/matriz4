algoritmo "matriz_3x4"
var
   M: vetor[1..3,1..4] de inteiro
   i, j: inteiro
inicio


   para i de 1 ate 3 faca
      para j de 1 ate 4 faca
         escreva("Digite o valor [", i, ",", j, "]: ")
         leia(M[i,j])
      fimpara
   fimpara


   escreval("Matriz digitada:")


   para i de 1 ate 3 faca
      para j de 1 ate 4 faca
         escreva(M[i,j], " ")
      fimpara
      escreval("")
   fimpara


fimalgoritmo
