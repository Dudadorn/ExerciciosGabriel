algoritmo "Ex1"

var
  contador, idade, maiores: inteiro

inicio
  contador <- 1
  maiores <- 0

  enquanto contador <= 10 faca 
    escreval("Digite a idade:")
    leia(idade)

  se idade >= 18 entao 
     maiores <- maiores + 1
  fimse

  contador <- contador + 1 
  fimenquanto

  escreval("Maiores de idade:", maiores)

fimalgoritmo
