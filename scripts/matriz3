algoritmo "soma_diagonal"
var
   A: vetor[1..4,1..4] de inteiro
   i, j, soma: inteiro
inicio
   soma <- 0


   para i de 1 ate 4 faca
      para j de 1 ate 4 faca
         escreva("Digite o valor [", i, ",", j, "]: ")
         leia(A[i,j])
      fimpara
   fimpara


   para i de 1 ate 4 faca
      soma <- soma + A[i,i]
   fimpara


   escreval("Soma da diagonal principal: ", soma)
fimalgoritmo
