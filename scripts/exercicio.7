algoritmo "ex7"
var
   contador: inteiro
   n1, n2, prox: inteiro
inicio
   n1 <- 0
   n2 <- 1
   contador <- 3

   escreval(n1)
   escreval(n2)

   enquanto contador <= 11 faca
      prox <- n1 + n2
      escreval(prox)

      n1 <- n2
      n2 <- prox

      contador <- contador + 1
   fimenquanto
fimalgoritmo
