algoritmo "ex6"
var
   i, quadrado: inteiro
  
inicio
   i <- 1

   enquanto i <= 10 faca
   quadrado <- i * i 
      escreval(i, "/", quadrado)
      i <- i + 1
   fimenquanto

   escreval(" ")

   i <- 1

   enquanto i <= 10 faca
      escreval((2*i-1), "/", i)
      i <- i + 1
   fimenquanto
fimalgoritmo
