algoritmo "Ex3"


var
 A: vetor[1..5] de inteiro
 B: vetor[1..5] de inteiro
 i: inteiro
 inicio


  para i de 1 ate 5 faca
    escreval("Digite A [", i,"]:")
    leia(A[i])
  fimpara


    para i de 1 ate 5 faca
    B[i] <- A[i] * A[i]
  fimpara


   escreval("vetor B:")
   para i de 1 ate 5 faca
   escreval(B[i])
   fimpara
fimalgoritmo
