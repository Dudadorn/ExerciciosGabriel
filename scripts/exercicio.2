algoritmo "Ex2"

var
  contador, idade : inteiro
  f1, f2, f3, f4, f5: inteiro 

inicio
  contador <- 1
 
    f1 <- 0
    f2 <- 0
    f3 <- 0
    f4 <- 0
    f5 <- 0 

    enquanto contador <= 15 faca
      escreval("Digite a idade:")
      leia(idade)
    se idade <= 15 entao
      f1 <- f1 + 1
    senao se idade <= 30 entao
      f2 <- f2 + 1
    senao se idade <= 45 entao
      f3 <- f3 + 1
    senao se idade <= 60 entao
      f4 <- f4 + 1
    senao 
      f5 <- f5 + 1
        fimse
      fimse
    fimse
  fimse


   contador <- contador + 1 
  fimenquanto

  escreval("1-15:", f1)
  escreval("16-30:", f2)
  escreval("31-45:", f3)
  escreval("46-60:", f4)
  escreval("61+:", f5)

fimalgoritmo
